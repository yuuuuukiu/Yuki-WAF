# ============================================================
#  Yuki-WAF  环境变量模板
#  复制为 .env 后按需修改：  cp .env.example .env
# ============================================================

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=yuki_root_2024
MYSQL_DATABASE=yuki_waf
MYSQL_USER=yuki
MYSQL_PASSWORD=yuki_pass_2024
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ---------- Kafka ----------
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC_RAW_REQUESTS=waf.raw_requests

# ---------- Backend (FastAPI) ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-to-a-random-string
DEBUG=true

# ---------- AI Provider (用户自定义) ----------
# 用户在前端填写，此处仅作为后端兜底 / 超级管理员默认配置
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ---------- Gateway ----------
GATEWAY_HTTP_PORT=8080
GATEWAY_HTTPS_PORT=8443
